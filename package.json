{
  "name": "crypto-visualizer-workspace",
  "version": "2.0.1",
  "private": true,
  "packageManager": "npm@10.8.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=web",
    "demo": "node demo.js",
    "dev:cipher": "turbo run dev --filter=web --filter=cipher-service",
    "dev:hash": "turbo run dev --filter=web --filter=hash-service",
    "dev:sym": "turbo run dev --filter=web --filter=sym-crypto-service",
    "dev:asym": "turbo run dev --filter=web --filter=asym-crypto-service",
    "dev:jwt": "turbo run dev --filter=web --filter=jwt-service",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test"
  },
  "devDependencies": {
    "turbo": "latest"
  }
}